{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite\" \"npm:dev:server\"",
    "dev:server": "nodemon server/index.js --watch server --ext js,json",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init --preview-feature"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.268.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.0",
    "cookie-parser": "^1.4.6",
    "pg": "^8.11.0",
    "@prisma/client": "^5.6.0",
    "concurrently": "^8.2.0"
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "prisma": "^5.6.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0"
  }
}
