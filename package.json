{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"sh -c 'docker-compose up || echo [dev] docker-compose unavailable - continuing without containers'\" \"vite\" \"npm:dev:server\"",
    "dev:server": "nodemon server/index.js --watch server --ext js,json",
    "db:ensure": "node scripts/dbEnsure.js",
    "build": "vite build",
    "vercel-build": "npm run prisma:generate && npm run build",
    "postinstall": "npm run prisma:generate",
    "preview": "vite preview",
    "format": "prettier --write .",
    "prisma:generate": "prisma generate",
    "prisma:format": "prisma format",
    "prisma:migrate": "prisma migrate dev --name init --preview-feature",
    "test": "npm run test:error-responses",
    "test:error-responses": "node scripts/test-error-responses.js"
  },
  "dependencies": {
    "@monaco-editor/react": "latest",
    "@prisma/client": "^5.6.0",
    "concurrently": "^8.2.0",
    "connect-pg-simple": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.4",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.0",
    "lucide-react": "^0.268.0",
    "pg": "^8.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^3.0.0",
    "vercel": "^50.37.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.0.0",
    "prisma": "^5.6.0",
    "vite": "^5.0.0"
  }
}
