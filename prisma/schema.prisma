generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(uuid())
  username         String     @unique
  avatar           String?
  suspended        Boolean    @default(false)
  isAdmin          Boolean    @default(false)
  adminRole        String? // "SUPER_ADMIN", "MODERATOR", "VIEWER"
  createdAt        DateTime   @default(now())
  commands         Command[]
  ratings          Rating[]
  favorites        Favorite[]
  followers        Follow[]   @relation("followers")
  following        Follow[]   @relation("following")
  reportsSubmitted Report[]   @relation("reporter")
  news             News[]

  @@index([createdAt])
  @@index([suspended])
  @@index([isAdmin])
}

model Command {
  id             String            @id @default(uuid())
  name           String            @unique
  description    String
  type           String
  framework      String
  uploadCategory String            @default("Framework")
  version        String
  tags           String[]          @default([])
  githubUrl      String?
  websiteUrl     String?
  downloads      Int               @default(0)
  rating         Float             @default(0)
  ratingCount    Int               @default(0)
  favourites     Int               @default(0)
  views          Int               @default(0)
  changelog      String?
  rawData        String
  approved       Boolean           @default(false)
  approvedBy     String?
  approvalReason String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  authorId       String
  author         User              @relation(fields: [authorId], references: [id])
  ratings        Rating[]
  favorites      Favorite[]
  analytics      CommandAnalytics?

  @@index([authorId])
  @@index([approved])
  @@index([type])
  @@index([framework])
  @@index([downloads])
  @@index([rating])
}

model Favorite {
  userId    String
  commandId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  command Command @relation(fields: [commandId], references: [id], onDelete: Cascade)

  @@id([userId, commandId])
  @@index([userId])
  @@index([createdAt])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([createdAt])
}

model CommandAnalytics {
  id        String   @id @default(uuid())
  commandId String   @unique
  command   Command  @relation(fields: [commandId], references: [id], onDelete: Cascade)
  views     Int      @default(0)
  downloads Int      @default(0)
  favorites Int      @default(0)
  ratings   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

model TrendingCommand {
  id         String   @id @default(uuid())
  commandId  String
  rank       Int
  timeWindow String // "weekly" or "monthly"
  score      Float
  computedAt DateTime @default(now())

  @@unique([commandId, timeWindow])
  @@index([rank])
  @@index([timeWindow])
}

model Rating {
  userId    String
  commandId String
  value     Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  command Command @relation(fields: [commandId], references: [id])

  @@id([userId, commandId])
}

model Share {
  id        String   @id @default(uuid())
  commandId String
  userId    String?
  platform  String // "twitter", "facebook", "linkedin", "discord", "reddit"
  createdAt DateTime @default(now())

  @@index([commandId])
  @@index([userId])
  @@index([platform])
  @@index([createdAt])
}

model Event {
  id        String   @id @default(uuid())
  commandId String
  type      String // "view" or "download"
  userId    String?
  createdAt DateTime @default(now())

  @@index([commandId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([commandId, type, createdAt])
}

model Report {
  id             String    @id @default(uuid())
  reporterId     String
  reporter       User      @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  commandId      String?
  userId         String?
  reason         String
  reportType     String // "spam", "abuse", "inappropriate", "copyright", "other"
  resolved       Boolean   @default(false)
  resolvedBy     String?
  resolutionNote String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?

  @@index([reporterId])
  @@index([commandId])
  @@index([userId])
  @@index([reportType])
  @@index([resolved])
  @@index([createdAt])
}

model News {
  id          String    @id @default(uuid())
  title       String
  content     String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdBy   String
  author      User      @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published])
  @@index([publishedAt])
  @@index([createdBy])
  @@index([createdAt])
}
