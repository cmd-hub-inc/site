# Copy to .env for local development and fill values
# For local Postgres (docker-compose), use:
DATABASE_URL=postgresql://postgres:password@localhost:5432/cmdhub

# In production (Vercel), set DATABASE_URL to your managed Postgres connection string

PORT=4000

# Discord OAuth settings
# Register an OAuth application at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# The server URL used as redirect URI (must match Discord app settings)
BASE_URL=http://localhost:4000
# Frontend URL where users should be redirected after login
CLIENT_URL=http://localhost:5173
