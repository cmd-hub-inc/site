# Copy to .env for local development and fill values
# For local Postgres (docker-compose), use:
DATABASE_URL=postgresql://postgres:password@localhost:5432/cmdhub

# In production (Vercel), set DATABASE_URL to your managed Postgres connection string

PORT=4000

# Discord OAuth settings
# Register an OAuth application at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
# The server URL used as redirect URI (must match Discord app settings)
BASE_URL=http://localhost:4000
# Frontend URL where users should be redirected after login
CLIENT_URL=http://localhost:5173
SESSION_SECRET=replace_this_with_a_strong_secret
# Frontend build-time API base for dev (used by Vite):
# Example: VITE_API_BASE=http://localhost:4000
VITE_API_BASE=http://localhost:4000

# Optional Redis URL for storing pending OAuth tokens (recommended in multi-process envs)
# When running with docker-compose, use: redis://localhost:6379
REDIS_URL=redis://localhost:6379
# Comma-separated Discord user IDs that should have admin access to the dashboard
ADMIN_IDS=comma_separated_discord_user_ids_for_admin_access

# When running frontend and backend separately, set the client origin and proxy target:
# CLIENT_URL=https://your-frontend.example
# PROXY_TARGET=https://your-backend.example

# If DATABASE_URL contains special characters in the password, percent-encode them.
