{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "headers": {
        "cache-control": "no-store, no-cache, no-transform, must-revalidate, private",
        "pragma": "no-cache",
        "expires": "0"
      },
      "continue": true
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
